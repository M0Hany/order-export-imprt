# Copy to .env for local dev. For production, set these on Render (see render.yaml header).

# Neon: Dashboard → project → Connect → copy pooled URI (include sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_orders,read_all_orders,write_draft_orders,write_orders

# Same as application_url in shopify.app.toml (no trailing slash)
SHOPIFY_APP_URL=
